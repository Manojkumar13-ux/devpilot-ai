# ─── Database (PostgreSQL) ────────────────────────────────────────
DATABASE_URL="postgresql://devpilot:devpilot@localhost:5432/devpilot"

# ─── Auth (JWT) ───────────────────────────────────────────────────
JWT_SECRET="generate-a-random-secret-with-openssl-rand-64"

# ─── Server ───────────────────────────────────────────────────────
BACKEND_PORT=4000
CORS_ORIGIN=http://localhost:5173

# ─── Redis (BullMQ job queue) ─────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── AI Provider ──────────────────────────────────────────────────
# Option A — Ollama (free, local, no API key needed for localhost)
#   OPENAI_API_KEY=""
#   OPENAI_MODEL="llama3.2:3b"
#   OPENAI_BASE_URL="http://localhost:11434/v1"
#
# Option B — OpenAI
#   OPENAI_API_KEY="sk-..."
#   OPENAI_MODEL="gpt-4-turbo-preview"
#   OPENAI_BASE_URL="https://api.openai.com/v1"
#
# Option C — Azure OpenAI
#   OPENAI_API_KEY="..."
#   OPENAI_MODEL="gpt-4"
#   OPENAI_BASE_URL="https://<resource>.openai.azure.com"
OPENAI_API_KEY=""
OPENAI_MODEL="llama3.2:3b"
OPENAI_BASE_URL="http://localhost:11434/v1"

# ─── Logging ──────────────────────────────────────────────────────
LOG_LEVEL=debug
